root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{js,jsx,ts,tsx,json,html,css,md,yml,yaml}]
indent_style = space
indent_size = 2

[*.rs]
indent_style = space
indent_size = 4

[*.{toml,lock}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
