{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "volt",
  "version": "0.0.4",
  "identifier": "volt.launch",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Volt",
        "width": 800,
        "height": 550,
        "minWidth": 700,
        "minHeight": 450,
        "resizable": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "focus": true,
        "fullscreen": false,
        "label": "main"
      },
      {
        "title": "Volt Settings",
        "width": 900,
        "height": 600,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "focus": true,
        "fullscreen": false,
        "label": "settings",
        "url": "settings.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://github.com https://*.githubusercontent.com https://objects.githubusercontent.com; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'",
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "publisher": "VoltLaunchr",
    "copyright": "© 2026 VoltLaunchr Contributors",
    "shortDescription": "Fast, beautiful desktop launcher for Windows, macOS, and Linux",
    "longDescription": "Volt is a modern, lightning-fast application launcher designed to boost your productivity. Launch apps, search files, and execute commands instantly with a sleek, customizable interface.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": null,
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "wix": {
        "language": ["en-US", "fr-FR"],
        "bannerPath": "icons/wix-banner.bmp",
        "dialogImagePath": "icons/wix-dialog.bmp"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English", "French"],
        "displayLanguageSelector": true,
        "compression": "lzma",
        "startMenuFolder": "Volt",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp"
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4MEZCNDU0QUQ1NjJFMzMKUldRekxsYXRWTFFQeUhlbVU1L2Q5MGNpbWdBbmdzSUxrdWhRaXk5WWthTTc3TVh6bHpxcmFHUmkK",
      "endpoints": ["https://github.com/VoltLaunchr/Volt/releases/latest/download/latest.json"]
    }
  }
}
