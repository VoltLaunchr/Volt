# Copy this file to .env and fill in your values. NEVER commit .env.
#
# Volt itself does not read any secret env vars at runtime. The variables
# below are only needed if you build/publish signed release artifacts for
# the Tauri auto-updater (see docs/build-release/DISTRIBUTION.md).

# Tauri auto-updater signing key (minisign)
# Generate with: bun tauri signer generate -w volt-update.key
# The value is the raw contents of the generated private key file.
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Optional: override the dev server host Tauri binds to (used by vite.config.ts).
# Leave empty unless you are debugging Tauri on a remote/physical device.
TAURI_DEV_HOST=

# Supabase auth (required for user authentication in the desktop app).
# Get these from your Supabase project dashboard → Settings → API.
# The anon key is safe to embed — RLS protects your data.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
