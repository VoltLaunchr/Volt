#!/usr/bin/env bash
# Volt pre-commit hook — runs typecheck + cargo fmt check before a commit is recorded.
# Enable with: bun run setup-hooks
set -e

echo "▸ tsc --noEmit"
bunx tsc --noEmit

if command -v cargo >/dev/null 2>&1; then
  echo "▸ cargo fmt --check (src-tauri)"
  (cd src-tauri && cargo fmt --all -- --check)
else
  echo "! cargo not found, skipping cargo fmt check"
fi

echo "✓ pre-commit checks passed"
